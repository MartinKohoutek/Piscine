{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build",
			"type": "shell",
			"command": "gcc",
			"args": [
				"-Wall",
				"-Wextra",
				"-Werror",
				"*.c",
				"-o",
				"program"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$gcc"
		},
		{
			"label": "Build and run",
			"type": "shell",
			"command": "gcc -Wall -Wextra -Werror *.c -o program && ./program",
			"options": {
				"cwd": "${fileDirname}"
			},
			"group": "test",
			"problemMatcher": "$gcc"
		},
		{
			"label": "Build for Debugger",
			"type": "shell",
			"command": "gcc",
			"args": [
				"-Wall",
				"-Wextra",
				"-Werror",
				"-g3",
				"-O0",
				"-fsanitize=address",
				"*.c",
				"-o",
				"program"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"group": "build",
			"problemMatcher": "$gcc"
		},
		{
			"label": "Norminette current",
			"type": "shell",
			"command": "norminette",
			"args": [
				"${file}"
			],
			"problemMatcher": []
		}
	]
}
